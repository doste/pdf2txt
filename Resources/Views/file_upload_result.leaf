
<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>File uploaded</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
  </head>
  <body>
    <h1>
        pdf2txt
    </h1>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO" crossorigin="anonymous"></script>
    
    
    #if(isValid):
        <h3>PDF File #(fileName) uploaded successfully. </h3>
        <h3> Its contents are: </h3>
        <hr />
        #for(page in fileContents):
            <p>#(page)</p>
        #endfor
        <hr />
    #else:
        <h3 style='color:red;'>Invalid file. Only txt supported.</h3>
    #endif


    <a href="/upload">Upload new one</a>
  </body>


    <style>
    body {
      color: #212121;
      font-family: Arial, sans-serif;
      scroll-behavior: smooth;
      font-size: 1.15rem;
      line-height: 1.5;
      max-width: 850px;
      margin: auto;
      padding-top: 1rem;
    }

    a {
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    select {
      font-size: 1.15rem;
      font-family: inherit;
      line-height: inherit;
      padding-left: 1rem;
    }

    select,
    #file-input-label {
      padding: 0.5em;
      border: thin solid grey;
      border-radius: 3px;
      cursor: pointer;
      background-color: #f6f6fb;
    }

    #input-container {
      margin-top: 2rem;
    }

    #input-container div {
      display: inline-block;
      margin-right: 1rem;
    }

    #loading,
    #error {
      margin-top: 2rem;
      margin-bottom: 3rem;
    }

    #loading {
      display: none;
    }

    section {
      border-top: 1px solid #898ea4;
      border-bottom: 1px solid #898ea4;
      padding: 2rem 1rem;
      margin: 3rem 0;
    }

    section + section,
    section:first-child {
      border-top: 0;
      padding-top: 0;
    }

    pre {
      font-family: Arial, sans-serif;
      margin: 0;
    }

    canvas {
      display: none;
    }
  </style>
</html>
